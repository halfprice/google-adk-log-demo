# Copy this file to .env and fill in your credentials:  cp .env.example .env
# Gemini auth — pick ONE of the two options below.

# Option A: AI Studio API key (simplest — get a free one at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Option B: Vertex AI via gcloud ADC (run `gcloud auth application-default login` first)
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Model used by all agents (optional override; free-tier daily quotas are per model)
DEMO_MODEL=gemini-3.1-flash-lite

# Simulated per-RPC latency in the mock tools, seconds (stretches the demo
# so several audit batches anchor mid-run, at zero extra LLM calls)
# DEMO_RPC_LATENCY=2.0
